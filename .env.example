# Gmail SMTP Configuration for VFA Diaries Email Verification
# Copy this file to .env and fill in your actual Gmail credentials

# Local server settings
HOST=127.0.0.1
PORT=8000

# SQLite database file.
# For production, point this at a persistent disk/volume path.
DATABASE_PATH=vfa_diaries.sqlite3

# Gmail SMTP Server Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false

# Your Gmail Address
SMTP_USERNAME=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate this at: https://myaccount.google.com/apppasswords
# Make sure 2-Step Verification is enabled on your Google Account
SMTP_PASSWORD=your-16-character-app-password

# Sender Email (usually same as SMTP_USERNAME)
SMTP_FROM=your-email@gmail.com
